#!/usr/bin/env python3
"""
claw — NanoClaw CLI (v2)
Send a message to your agent via the CLI Unix socket.

Usage:
  claw "What is 2+2?"
  claw --list-groups
  echo "prompt" | claw --pipe
"""

from __future__ import annotations

import argparse
import json
import os
import socket
import sys
from pathlib import Path


def _find_nanoclaw_dir() -> Path:
    if env := os.environ.get("NANOCLAW_DIR"):
        return Path(env).expanduser()
    here = Path(__file__).resolve()
    for parent in [here.parent, here.parent.parent]:
        if (parent / ".env").exists() or (parent / "data" / "v2.db").exists():
            return parent
    return Path.home() / "src" / "nanoclaw"


NANOCLAW_DIR = _find_nanoclaw_dir()
SOCK_PATH    = NANOCLAW_DIR / "data" / "cli.sock"
DB_PATH      = NANOCLAW_DIR / "data" / "v2.db"


def list_groups():
    try:
        import sqlite3
        conn = sqlite3.connect(DB_PATH)
        rows = conn.execute(
            """SELECT ag.name, ag.id, mg.platform_id, mg.channel_type
               FROM agent_groups ag
               LEFT JOIN messaging_group_agents mga ON mga.agent_group_id = ag.id
               LEFT JOIN messaging_groups mg ON mg.id = mga.messaging_group_id
               ORDER BY ag.name"""
        ).fetchall()
        conn.close()
        print(f"{'NAME':<35} {'ID':<30} {'PLATFORM'}")
        print("-" * 90)
        for name, gid, platform_id, channel_type in rows:
            plat = f"{channel_type}:{platform_id}" if platform_id else "(unwired)"
            print(f"{name:<35} {gid:<30} {plat}")
    except Exception as e:
        print(f"error: could not read groups: {e}", file=sys.stderr)
        sys.exit(1)


def send_and_receive(text: str, timeout: int = 300) -> None:
    if not SOCK_PATH.exists():
        print(f"error: CLI socket not found at {SOCK_PATH}", file=sys.stderr)
        print("Is NanoClaw running? Check: launchctl list | grep nanoclaw", file=sys.stderr)
        sys.exit(1)

    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect(str(SOCK_PATH))
    except Exception as e:
        print(f"error: could not connect to CLI socket: {e}", file=sys.stderr)
        sys.exit(1)

    payload = json.dumps({"text": text}) + "\n"
    sock.sendall(payload.encode())

    sock.settimeout(timeout)
    buf = ""
    try:
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buf += chunk.decode(errors="replace")
            while "\n" in buf:
                line, buf = buf.split("\n", 1)
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                    if isinstance(msg, dict) and "text" in msg:
                        print(msg["text"])
                        return
                    else:
                        print(line)
                        return
                except json.JSONDecodeError:
                    print(line)
                    return
    except socket.timeout:
        print("error: timed out waiting for agent response", file=sys.stderr)
        sys.exit(1)
    finally:
        sock.close()


def main():
    parser = argparse.ArgumentParser(prog="claw", description="Talk to your NanoClaw agent from the terminal.")
    parser.add_argument("prompt", nargs="?", help="Message to send")
    parser.add_argument("--list-groups", action="store_true", help="List registered agent groups")
    parser.add_argument("--pipe", action="store_true", help="Read prompt from stdin")
    parser.add_argument("--timeout", type=int, default=300, help="Seconds to wait for response (default: 300)")
    args = parser.parse_args()

    if args.list_groups:
        list_groups()
        return

    if args.pipe:
        text = sys.stdin.read().strip()
    elif args.prompt:
        text = args.prompt
    else:
        parser.print_help()
        sys.exit(1)

    if not text:
        print("error: empty prompt", file=sys.stderr)
        sys.exit(1)

    send_and_receive(text, timeout=args.timeout)


if __name__ == "__main__":
    main()
